### PREORDER

import java.util.*;

class Node1 {
    int data;
    Node1 left, right;

    public Node1(int data) {
        this.data = data;
        this.left = null;
        this.right = null;
    }
}

class Tree1 {
    Node1 root;

    public Tree1() {
        root = null;
    }

    // Insert using Level Order
    public void insert(int data) {
        if (root == null) {
            root = new Node1(data);
            return;
        }

        Queue<Node1> q = new LinkedList<>();

        q.offer(root);

        while (!q.isEmpty()) {
            Node1 cur = q.poll();

            if (cur.left == null) {
                cur.left = new Node1(data);
                return;
            } else {
                q.offer(cur.left);
            }

            if (cur.right == null) {
                cur.right = new Node1(data);
                return;
            } else {
                q.offer(cur.right);
            }
        }
    }

    // Preorder Traversal (Root -> Left -> Right)
    public void preorder(Node1 node) {

        if (node == null)
            return;

        System.out.print(node.data + " ");
        preorder(node.left);
        preorder(node.right);
    }
}

