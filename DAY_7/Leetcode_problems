class Solution {

    public int range(int[] a, int t, boolean flag) {
        int l = 0, h = a.length - 1;
        int possible = -1;

        while (l <= h) {
            int m = l + (h - l) / 2;

            if (a[m] == t) {
                possible = m;

                if (flag) {
                    h = m - 1; // find first occurrence
                } else {
                    l = m + 1; // find last occurrence
                }
            } else if (a[m] > t) {
                h = m - 1;
            } else {
                l = m + 1;
            }
        }

        return possible;
    }

    public int[] searchRange(int[] nums, int target) {
        return new int[] {
            range(nums, target, true),
            range(nums, target, false)
        };
    }
}
