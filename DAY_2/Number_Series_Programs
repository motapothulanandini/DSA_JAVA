3.SPy Number
123=>(1+2+3)=(1*2*3) ->spy number
class Solution {
    public boolean checkSpy(int n)
    {
        int s=0;
        int m=1;
        int p=n;
        while(p>0)
        {
            int d=p%10;
            s+=d;
            m*=d;
            p/=10;
        }
       
        if(s==m)
        {
            return true;
        }
        return false;
    }
}

4. Automorphic Number
class Solution {
    public String isAutomorphic(int n)
    {
        int s=n*n;
        int tempn=n;
        int temps=s;
        boolean a= true;
        while(tempn>0)
        {
            if(tempn%10!=temps%10)
            {
               a=false;
                break;
            }
            tempn/=10;
            temps/=10;
        }
        if(a)
        {
            return "Automorphic";
        }
        return "Not Automorphic";
        
    }
}

5.Magic number

class Main
{
    public static void main(String args[])
    {
        int n=19;
        while(n>9)
        {
            int s=0;
            while(n>0)
            {
                int d=n%10;
                s+=d;
                n/=10;
            }
            n=s;
        }
       
         if(n==1)
         {
             System.out.println("magic number");
         }
         else
         {
             System.out.println("not a magic number");
         }
      }
    }


