7.Perfect Number

class Solution {
    static boolean isPerfect(int n) 
    {
        

        int sum = 1; // 1 is always a divisor

        for (int i = 2; i * i <= n; i++) {

            if (n % i == 0) {
                sum += i;

                if (i != n / i) {
                    sum += n / i;
                }
            }
        }

        return sum == n && n != 1;
    }
}
        
        
    
